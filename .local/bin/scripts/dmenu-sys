#!/usr/bin/env bash

case "$(printf "kill\nzzz\nhybrid\nhibernate\nreboot\nshutdown" | dmenu -i -l 6)" in
	kill) ps -u $USER -o pid,comm,%cpu,%mem | dmenu -i -l 10 -p Kill: | awk '{print $1}' | xargs -r kill ;;
	zzz) slock systemctl suspend -i ;;
    hybrid) systemctl hybrid-sleep ;;
    hibernate) systemctl hibernate -i ;;
	reboot) systemctl reboot -i ;;
	shutdown) shutdown now ;;
	*) exit 1 ;;
esac
