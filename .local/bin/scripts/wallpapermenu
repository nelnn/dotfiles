#!/bin/sh

FOLDER=~/pics/wallpaper
SCRIPT=~/.local/bin/scripts/pywal16

menu() {
  CHOICE=$(nsxiv -otb $FOLDER/*) # nsxiv -o writes filename to stdout

  case $CHOICE in
    *.*) wal -i "$CHOICE" -s -o $SCRIPT ;;
    *) exit 0;;
  esac
}

case "$#" in
  0) menu ;;
  1) wal -i "$1" -s -o $SCRIPT ;;
  2) wal -i "$1" -s --theme $2 -o $SCRIPT ;;
  *) exit 0 ;
esac
